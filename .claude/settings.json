{
  "mcpServers": {
    "loofi-workflow": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "-u",
        "scripts/mcp_workflow_server.py"
      ]
    },
    "loofi-agent-sync": {
      "type": "stdio",
      "command": "python3",
      "args": [
        "-u",
        "scripts/mcp_agent_sync_server.py"
      ]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.cjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-tool-use.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.cjs"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-tool-use.cjs"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ""
          }
        ]
      }
    ]
  }
}
